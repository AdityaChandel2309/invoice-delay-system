# ── Database ──────────────────────────────────────────────────────────
# Connection string used by both the backend API and Alembic migrations.
# When running with docker-compose the hostname is the service name "db".
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/invoice_delay

# ── Application ───────────────────────────────────────────────────────
APP_NAME=Invoice Delay Prediction System
APP_VERSION=0.1.0
DEBUG=false

# ── API ───────────────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1

# ── ML Models ─────────────────────────────────────────────────────────
# Directory where joblib model files are stored (relative to working dir).
ML_MODELS_DIR=ml_models
